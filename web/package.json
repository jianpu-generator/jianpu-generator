{
  "name": "jianpu-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "build:wasm": "wasm-pack build ../crates/jianpu-wasm --target web --out-dir pkg --no-opt -- --features wav,pdf",
    "build:wasm:audio": "wasm-pack build ../crates/jianpu-wasm --target web --out-dir pkg --no-opt -- --features wav",
    "predev": "wasm-pack build ../crates/jianpu-wasm --target web --out-dir pkg --no-opt -- --features wav,pdf",
    "dev": "vite",
    "prebuild": "wasm-pack build ../crates/jianpu-wasm --target web --out-dir pkg --no-opt -- --features wav,pdf",
    "build": "tsc -b && vite build",
    "check": "knip --include files,dependencies",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "preview": "vite preview",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@github/hotkey": "^3.1.4",
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-progress": "^1.1.10",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-tooltip": "^1.2.10",
    "lucide-react": "^1.21.0",
    "lz-string": "^1.5.0",
    "monaco-editor": "^0.55.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "remeda": "^2.39.0",
    "usehooks-ts": "^3.1.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@playwright/test": "^1.60.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "knip": "^6.16.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "wasm-pack": "^0.15.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "wasm-pack"
    ]
  }
}
